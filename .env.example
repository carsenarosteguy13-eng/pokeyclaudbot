# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# eBay (Production)
# App credentials from developer.ebay.com
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
# Long-lived refresh token from eBay OAuth flow
EBAY_REFRESH_TOKEN=your_ebay_refresh_token
# Your ZIP code — used to create the seller location if none exists
SELLER_ZIP_CODE=10001

# Imgbb — free image hosting, required so eBay can load your photos
# Get a free key at imgbb.com/api
IMGBB_API_KEY=your_imgbb_api_key
